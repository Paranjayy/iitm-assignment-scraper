{
  "manifest_version": 3,
  "name": "IITM Assignment Scraper",
  "version": "1.2.0",
  "description": "Adds a button to download IITM online degree assignments as a clean Markdown file.",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "offscreen",
    "storage",
    "clipboardWrite",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://seek.onlinedegree.iitm.ac.in/*",
    "*://score-checker-379619009600.asia-south1.run.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://seek.onlinedegree.iitm.ac.in/*",
        "*://score-checker-379619009600.asia-south1.run.app/*"
      ],
      "js": ["turndown.js", "jszip.min.js", "content.js", "portal_enhancements.js"],
      "css": ["inject_button.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_title": "Scrape IITM Assignment"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "commands": {
    "unlock_page": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Unlock Editor and Copy-Paste on current page"
    }
  }
}